# ============================================
# SQL Server (senha do SA do container)
# Mínimo 8 chars, maiúsculas, minúsculas, número e símbolo
# ============================================
MSSQL_SA_PASSWORD=SuaSenhaForte@123

# ============================================
# JWT
# ============================================
JWT_SECRET=sua-chave-secreta-super-forte-minimo-32-caracteres
JWT_EXPIRES_IN=8h

# ============================================
# Active Directory (servidor externo ao Docker)
# ============================================
AD_URL=ldap://192.168.1.1
AD_BASE_DN=DC=empresa,DC=local
AD_SERVICE_USER=servico_ldap@empresa.local
AD_SERVICE_PASSWORD=senha_servico_ldap
AD_DOMAIN=EMPRESA

# ============================================
# URL pública do frontend (usada pelo CORS)
# ============================================
FRONTEND_URL=http://localhost
