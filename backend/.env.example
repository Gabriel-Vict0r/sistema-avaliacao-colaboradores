# ============================================
# CONFIGURAÇÕES DO SERVIDOR
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# SQL SERVER - Banco de Dados Local
# ============================================
# Autenticação SQL Server:
DATABASE_URL="sqlserver://localhost:1433;database=avaliacao_db;user=sa;password=SuaSenha;trustServerCertificate=true"

# Autenticação Windows Integrada (se preferir):
# DATABASE_URL="sqlserver://localhost:1433;database=avaliacao_db;integratedSecurity=true;trustServerCertificate=true"

# ============================================
# JWT
# ============================================
JWT_SECRET=sua-chave-secreta-super-forte-minimo-32-caracteres
JWT_EXPIRES_IN=8h

# ============================================
# ACTIVE DIRECTORY
# ============================================
# URL do servidor LDAP (Domain Controller)
AD_URL=ldap://192.168.1.1
# Base DN do domínio (ex: DC=empresa,DC=local)
AD_BASE_DN=DC=empresa,DC=local
# Conta de serviço para consultas LDAP (leitura)
AD_SERVICE_USER=servico_ldap@empresa.local
AD_SERVICE_PASSWORD=senha_servico_ldap
# Domínio NetBIOS (prefixo, ex: EMPRESA)
AD_DOMAIN=EMPRESA

# ============================================
# CORS - Frontend
# ============================================
FRONTEND_URL=http://localhost:5173

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
